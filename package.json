{
    "name": "@cosmos-registry/wasm-registry",
    "version": "0.1.0",
    "description": "TypeScript client for Cosm Registry CosmWasm contract",
    "license": "MIT",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Cosmos-registry/cosmos-registry-js.git"
    },
    "homepage": "https://github.com/Cosmos-registry/cosmos-registry-js",
    "bugs": {
        "url": "https://github.com/Cosmos-registry/cosmos-registry-js/issues"
    },
    "scripts": {
        "sync:schemas": "bash scripts/sync-schemas.sh",
        "build": "tsc -p tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@cosmjs/cosmwasm-stargate": "^0.38.1"
    },
    "devDependencies": {
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    }
}
